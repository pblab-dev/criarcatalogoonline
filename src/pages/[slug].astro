---
import {
	getPostBySlug,
	getRecommendedPosts,
	getAllPublishedPosts,
} from "../lib/blogQueries";
import BlogFooter from "../components/BlogFooter.astro";
import { getSiteSettings } from "../lib/models/site-settings";
import { getCategoriesWithCounts } from "../lib/models/post";
import { getStructuredDataSettings } from "../lib/models/structured-data-settings";

export const prerender = false;

const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : null;

if (!post) {
	return Astro.redirect("/", 404);
}

const recommendedPosts = await getRecommendedPosts(post.slug);
const categories = await getCategoriesWithCounts();
const imagePath = post.image?.url;
const imageUrl = imagePath ? `${imagePath}` : "";
const settings = await getSiteSettings();
const structured = await getStructuredDataSettings();

const decodeContentHtml = (value: string): string => {
	if (!value) return "";
	return value
		.replace(/&lt;/g, "<")
		.replace(/&gt;/g, ">")
		.replace(/&amp;/g, "&")
		.replace(/&quot;/g, '"')
		.replace(/&#39;/g, "'");
};
const siteTitle = settings.siteTitle || "Blog Alziro Duarte";
const siteDescription = settings.siteDescription || "Blog";
const primaryColor = settings.primaryColor || "#1D1760";
const secondaryColor = settings.secondaryColor || "#2563eb";
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<link rel="icon" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={siteDescription} />
		<meta name="keywords" content={post.tags.join(", ")} />
		<meta property="og:title" content={post.title} />
		<meta property="og:description" content={post.excerpt} />
		<meta property="og:type" content="article" />
		<meta property="article:author" content={post.author.name} />
		<meta
			property="article:published_time"
			content={post.publishedAt?.toISOString() ?? ""}
		/>
		<meta property="article:section" content={post.category?.name ?? ""} />
		{post.tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<title>{post.title} | {siteTitle}</title>
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="article" />
		<meta
			property="og:url"
			content={`${structured.siteUrl}/${post.slug}`}
		/>
		<meta property="og:title" content={post.title} />
		<meta property="og:description" content={post.excerpt} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="900" />
		<meta property="og:locale" content="pt_BR" />
		<meta property="og:site_name" content={siteTitle} />
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta
			name="twitter:url"
			content={`${structured.siteUrl}/${post.slug}`}
		/>
		<meta name="twitter:title" content={post.title} />
		<meta name="twitter:description" content={post.excerpt} />
		<meta name="twitter:image" content={imageUrl} />
		<link rel="stylesheet" href="/styles.css" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&display=swap"
			rel="stylesheet"
		/>
		<link rel="canonical" href={`${structured.siteUrl}/${post.slug}`} />
		<link rel="sitemap" type="application/xml" href="/sitemap.xml" />
		<style
			is:inline
			set:html={`:root { --blue-dark: ${primaryColor}; --blue-medium: ${secondaryColor}; }`}
		></style>
		<style>
			.navbar {
				position: relative;
				background: var(--blue-dark);
				padding: 15px 0;
			}
		</style>
		{
			(() => {
				const origin = Astro.url.origin ?? structured.siteUrl;
				const siteUrl = structured.siteUrl || origin;
				const baseUrl = siteUrl.endsWith("/")
					? siteUrl.slice(0, -1)
					: siteUrl;
				const canonicalUrl = `${baseUrl}/${post.slug}`;
				const logoUrl = structured.logoUrl || `${siteUrl}/logo2.png`;
				const orgId = `${siteUrl}/#organization`;
				const websiteId = `${siteUrl}/#website`;
				const webpageId = `${canonicalUrl}#webpage`;
				const breadcrumbId = `${canonicalUrl}#breadcrumb`;

				const graph = {
					"@context": "https://schema.org",
					"@graph": [
						{
							"@type": ["LocalBusiness", "Organization"],
							"@id": orgId,
							name: structured.organizationName,
							url: siteUrl,
							email: structured.contactEmail,
							address: {
								"@type": "PostalAddress",
								addressCountry: structured.addressCountry,
								addressLocality: structured.addressLocality,
								addressRegion: structured.addressRegion,
							},
							logo: {
								"@type": "ImageObject",
								url: logoUrl,
								contentUrl: logoUrl,
								caption: structured.logoCaption,
								inLanguage: "pt-BR",
							},
							telephone: structured.telephone,
							description: structured.description,
						},
						{
							"@type": "WebSite",
							"@id": websiteId,
							url: siteUrl,
							name: structured.websiteName,
							alternateName: structured.websiteAlternateName,
							publisher: {
								"@id": orgId,
							},
							inLanguage: "pt-BR",
						},
						{
							"@type": "WebPage",
							"@id": webpageId,
							url: canonicalUrl,
							name: post.title,
							datePublished:
								post.publishedAt?.toISOString() ?? undefined,
							dateModified:
								post.updatedAt?.toISOString?.() ?? undefined,
							isPartOf: {
								"@id": websiteId,
							},
							primaryImageOfPage: imageUrl
								? {
										"@type": "ImageObject",
										url: imageUrl,
									}
								: undefined,
							inLanguage: "pt-BR",
						},
						{
							"@type": "BlogPosting",
							"@id": `${canonicalUrl}#richSnippet`,
							headline: post.title,
							keywords: post.tags.join(", "),
							datePublished:
								post.publishedAt?.toISOString() ?? undefined,
							dateModified:
								post.updatedAt?.toISOString?.() ?? undefined,
							articleSection: post.category?.name ?? undefined,
							author: {
								"@type": "Person",
								name: post.author.name,
							},
							publisher: {
								"@id": orgId,
							},
							description: post.excerpt,
							name: post.title,
							isPartOf: {
								"@id": webpageId,
							},
							image: imageUrl
								? {
										"@type": "ImageObject",
										url: imageUrl,
									}
								: undefined,
							inLanguage: "pt-BR",
							mainEntityOfPage: {
								"@id": webpageId,
							},
						},
						{
							"@type": "BreadcrumbList",
							"@id": breadcrumbId,
							itemListElement: [
								{
									"@type": "ListItem",
									position: 1,
									item: {
										"@id": siteUrl,
										name: "Home",
									},
								},
								{
									"@type": "ListItem",
									position: 2,
									item: {
										"@id": `${siteUrl}/`,
										name: "Blog",
									},
								},
								{
									"@type": "ListItem",
									position: 3,
									item: {
										"@id": canonicalUrl,
										name: post.title,
									},
								},
							],
						},
					],
				};

				return (
					<script
						type="application/ld+json"
						class="rank-math-schema"
						set:html={JSON.stringify(graph)}
					/>
				);
			})()
		}
	</head>
	<body>
		<!-- Navbar -->
		<nav class="navbar">
			<div class="navbar-container">
				<div class="navbar-logo">
					<a href="/">
						<img
							src="/logo2.png"
							alt="Alziro Duarte - Comprar Avaliações Google 5 Estrelas"
						/>
					</a>
				</div>

				<button class="navbar-toggle" aria-label="Toggle menu">
					<span></span>
					<span></span>
					<span></span>
				</button>
				<ul class="navbar-menu">
					<li><a class="navbar-link" href="/">Início</a></li>
					{
						categories.slice(0, 8).map((item) => (
							<li>
								<a
									class="navbar-link"
									href={`/categoria/${item.category.slug}`}
								>
									{item.category.name}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</nav>

		<!-- Article Content -->
		<article class="blog-article">
			<div class="container">
				<div class="blog-article-layout">
					<!-- Main Article -->
					<main class="blog-article-main">
						<header class="blog-article-header">
							<div class="blog-article-meta">
								<a
									class="blog-article-category"
									href={`/categoria/${post.category?.slug}`}
								>
									{post.category?.name}
								</a>
								<span class="blog-article-date">
									{
										post.publishedAt
											? new Date(
													post.publishedAt,
												).toLocaleDateString("pt-BR", {
													day: "numeric",
													month: "long",
													year: "numeric",
												})
											: ""
									}
								</span>
							</div>
							<h1 class="blog-article-title">{post.title}</h1>
							<div class="blog-article-author-info">
								<span class="blog-article-author">
									{post.author.name}
								</span>
								<span class="blog-article-read-time">
									{post.readTime} min de leitura
								</span>
							</div>
							<div class="blog-article-tags">
								{
									post.tags.map((tag) => (
										<a
											href={`/tag/${tag}`}
											class="blog-tag"
										>
											{tag}
										</a>
									))
								}
							</div>
						</header>
						<img
							src={imagePath}
							alt={post.title}
							class="blog-article-image"
						/>
						<div
							class="blog-article-content"
							style="font-weight: 300;"
							set:html={decodeContentHtml(post.content)}
						/>

						<footer class="blog-article-footer">
							<div class="blog-article-share">
								<span>Compartilhar:</span>
								<a
									href={`https://www.facebook.com/sharer/sharer.php?u=https://criarcatalogoonline.online/${post.slug}`}
									target="_blank"
									rel="noopener noreferrer"
									class="blog-share-link"
								>
									Facebook
								</a>
								<a
									href={`https://twitter.com/intent/tweet?url=https://criarcatalogoonline.online/${post.slug}&text=${encodeURIComponent(
										post.title,
									)}`}
									target="_blank"
									rel="noopener noreferrer"
									class="blog-share-link"
								>
									Twitter
								</a>
								<a
									href={`https://www.linkedin.com/sharing/share-offsite/?url=https://criarcatalogoonline.online/${post.slug}`}
									target="_blank"
									rel="noopener noreferrer"
									class="blog-share-link"
								>
									LinkedIn
								</a>
							</div>
						</footer>
					</main>

					<!-- Sidebar -->
					<aside class="blog-sidebar">
						<!-- Recommended Posts -->
						<div class="blog-sidebar-section">
							<h3 class="blog-sidebar-title">
								Artigos Recomendados
							</h3>
							<div class="blog-sidebar-posts">
								{
									recommendedPosts.map((recPost) => (
										<article class="blog-sidebar-post">
											<a
												href={`/${recPost.slug}`}
												class="blog-sidebar-link"
											>
												<h4 class="blog-sidebar-post-title">
													{recPost.title}
												</h4>
												<p class="blog-sidebar-post-excerpt">
													{recPost.excerpt.substring(
														0,
														80,
													)}
													...
												</p>
											</a>
										</article>
									))
								}
							</div>
						</div>

						<!-- Latest Posts -->
						<div class="blog-sidebar-section">
							<h3 class="blog-sidebar-title">
								Últimas Postagens
							</h3>
							<ul class="blog-sidebar-list">
								{
									(await getAllPublishedPosts()).map(
										(latestPost) => (
											<li>
												<a
													href={`/${latestPost.slug}`}
													class="blog-sidebar-list-link"
												>
													{latestPost.title}
												</a>
											</li>
										),
									)
								}
							</ul>
						</div>
					</aside>
				</div>
			</div>
		</article>

		<BlogFooter recommendedPosts={recommendedPosts} />

		<script>
			const navbarToggle = document.querySelector(".navbar-toggle");
			const navbarMenu = document.querySelector(".navbar-menu");

			if (navbarToggle && navbarMenu) {
				navbarToggle.addEventListener("click", () => {
					navbarToggle.classList.toggle("active");
					navbarMenu.classList.toggle("active");
				});

				const navbarLinks = document.querySelectorAll(".navbar-link");
				navbarLinks.forEach((link) => {
					link.addEventListener("click", () => {
						navbarToggle.classList.remove("active");
						navbarMenu.classList.remove("active");
					});
				});
			}
		</script>
	</body>
</html>
